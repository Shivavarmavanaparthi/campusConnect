MONGO_URL=mongodb+srv://<user>:<password>@<cluster>/<db>?appName=Cluster1
ACCESS_TOKEN_SECRET=<access-secret>
REFRESH_TOKEN_SECRET=<refresh-secret>
REDIS_URL=rediss://<redis-user>:<redis-pass>@<host>:6379

OPENAI_API_KEY=<openai-or-sambanova-key>
OPENAI_BASE_URL=https://api.sambanova.ai/v1
OPENAI_MODEL=<model-name-or-leave-empty-if-autodiscovery-is-supported>

CLOUDINARY_CLOUD_NAME=<cloudinary-cloud-name>
CLOUDINARY_API_KEY=<cloudinary-api-key>
CLOUDINARY_API_SECRET=<cloudinary-api-secret>

